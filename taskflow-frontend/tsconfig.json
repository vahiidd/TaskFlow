{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",

    "types": [ "vitest", "vite/client" ]
  },
  "include": [
    "src",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts"
  ]
}
